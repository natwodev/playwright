{
  "name": "xspire-standard-playwright",
  "version": "1.0.0",
  "description": "Xspire standard version full E2E Testing solution is based on MS Playwright, Artillery which enables reliable end-to-end webapp functional and load testing.",
  "main": "index.js",
  "keywords": [
    "playwright",
    "typescript",
    "testing",
    "xspire"
  ],
  "author": "HQ Software",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "env": {
    "node": true,
    "browser": true
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.28.0",
    "eslint-plugin-jsdoc": "^46.4.6",
    "eslint-plugin-playwright": "^0.15.3",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "dotenv": "^16.4.7",
    "ts-node": "^10.9.2",
    "webdriverio": "^9.12.0",
    "winston": "^3.17.0"
  },
  "scripts": {
    "test:e2e": "npx playwright test tests/e2e/specs/ --headed --config=playwright.config.ts",
    "report": "npx playwright show-report",
    "lint": "eslint tests/**/*.ts src/**/*.ts playwright.config.ts",
    "lint:fix": "eslint tests/**/*.ts src/**/*.ts playwright.config.ts --fix",
    "format": "prettier --write tests/**/*.ts src/**/*.ts playwright.config.ts **/*.json **/*.md !package-lock.json !dist/**/* !build/**/*"
  }
}
